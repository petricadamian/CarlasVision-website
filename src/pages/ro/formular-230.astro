---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../i18n/translations";
import org from "../../data/organizatie.json";

const lang = "ro";
const tr = t(lang);
---

<Layout title="Formular 230" lang={lang} currentPage="form230">
  <!-- Header -->
  <section class="bg-gradient-to-br from-navy-900 to-navy-700 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold mb-4">{tr.form230.title}</h1>
      <p class="text-navy-200 text-xl max-w-2xl">{tr.form230.subtitle}</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Info box -->
      <div class="bg-navy-50 border border-navy-100 rounded-2xl p-8 mb-10">
        <p class="text-navy-800 leading-relaxed text-lg">{tr.form230.description}</p>
      </div>

      <!-- External link CTA -->
      <div class="bg-gradient-to-br from-navy-900 to-navy-700 rounded-2xl p-10 text-center text-white shadow-xl">
        <div class="w-16 h-16 bg-amber-brand/20 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-amber-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h2 class="text-2xl font-bold mb-3">Completează Formularul 230 online</h2>
        <p class="text-navy-200 mb-8 max-w-lg mx-auto">
          Folosește platforma <strong class="text-white">formular230.ro</strong> pentru a completa și depune formularul rapid, simplu și gratuit — direct pentru Asociația Carla's Vision.
        </p>
        <a
          href="https://formular230.ro/asociatia-carla-s-vision"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 bg-amber-brand text-navy-950 font-bold text-lg rounded-xl hover:bg-amber-brand-dark transition-colors shadow-lg"
        >
          Completează acum
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
        <p class="text-navy-400 text-sm mt-6">
          Vei fi redirecționat către formular230.ro — serviciu extern de încredere
        </p>
      </div>

      <!-- Steps -->
      <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-6">
        {[
          { num: "1", title: "Accesezi link-ul", text: "Dai click pe butonul de mai sus și ești redirecționat automat." },
          { num: "2", title: "Completezi datele", text: "Introdu datele tale personale în formularul online securizat." },
          { num: "3", title: "Trimiți formularul", text: "Formularul ajunge direct la ANAF. Fără drumuri, fără hârtii." },
        ].map((step) => (
          <div class="text-center">
            <div class="w-12 h-12 bg-navy-900 text-white rounded-full flex items-center justify-center text-lg font-extrabold mx-auto mb-3 shadow">
              {step.num}
            </div>
            <h3 class="font-bold text-navy-900 mb-1">{step.title}</h3>
            <p class="text-muted text-sm leading-relaxed">{step.text}</p>
          </div>
        ))}
      </div>

      <!-- Contact -->
      <div class="mt-12 text-center text-muted text-sm">
        <p>Ai nevoie de ajutor? Scrie-ne la <a href={`mailto:${org.email}`} class="text-navy-700 font-semibold hover:underline">{org.email}</a></p>
      </div>
    </div>
  </section>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import { t, routes } from "../../i18n/translations";
import { getCollection } from "astro:content";

const lang = "ro";
const tr = t(lang);
const r = routes[lang];

const proiecte = await getCollection("proiecte");
const proiecteSortate = proiecte.sort(
  (a, b) => b.data.data.getTime() - a.data.data.getTime()
);
---

<Layout title="Proiecte" lang={lang} currentPage="projects">
  <!-- Header -->
  <section class="bg-gradient-to-br from-navy-900 to-navy-700 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold mb-4">{tr.projects.title}</h1>
      <p class="text-navy-200 text-xl max-w-2xl">{tr.projects.subtitle}</p>
    </div>
  </section>

  <!-- Projects grid -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {proiecteSortate.map((proiect) => (
          <article class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col">
            <div class="bg-navy-100 h-48 flex items-center justify-center relative">
              {proiect.data.imagine ? (
                <img src={proiect.data.imagine} alt={proiect.data.titlu} class="w-full h-full object-cover" />
              ) : (
                <svg class="w-20 h-20 text-navy-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              )}
              <div class="absolute top-3 right-3 bg-navy-900 text-white text-xs px-2 py-1 rounded-full">
                {proiect.data.data.toLocaleDateString("ro-RO", { year: "numeric", month: "short" })}
              </div>
            </div>
            <div class="p-6 flex flex-col flex-1">
              <h2 class="font-bold text-navy-900 text-xl mb-3">{proiect.data.titlu}</h2>
              <p class="text-body text-sm leading-relaxed mb-4 flex-1">{proiect.data.descriere}</p>
              <div class="flex items-center justify-between text-sm text-muted pt-4 border-t border-gray-100">
                <span class="flex items-center gap-1.5 font-medium text-navy-700">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  {proiect.data.beneficiari} {tr.projects.beneficiaries}
                </span>
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  </svg>
                  {proiect.data.locatie}
                </span>
              </div>
              {proiect.data.tags && (
                <div class="flex gap-2 flex-wrap mt-3">
                  {proiect.data.tags.map((tag) => (
                    <span class="bg-navy-50 text-navy-700 text-xs px-2 py-0.5 rounded-full">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>

      <!-- Add project note -->
      <div class="mt-12 p-6 bg-amber-50 border border-amber-200 rounded-xl text-center">
        <p class="text-amber-800 font-medium">
          💡 Adaugă proiecte noi creând fișiere <code class="bg-amber-100 px-1 rounded">.md</code> în folderul{" "}
          <code class="bg-amber-100 px-1 rounded">src/content/proiecte/</code>
        </p>
      </div>
    </div>
  </section>
</Layout>

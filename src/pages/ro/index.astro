---
import Layout from "../../layouts/Layout.astro";
import { t, routes } from "../../i18n/translations";
import { getCollection } from "astro:content";
import org from "../../data/organizatie.json";

const lang = "ro";
const tr = t(lang);
const r = routes[lang];

const allProiecte = await getCollection("proiecte");
const proiecteRecente = allProiecte
  .sort((a, b) => b.data.data.getTime() - a.data.data.getTime())
  .slice(0, 3);
---

<Layout title="Acasă" lang={lang} currentPage="home">
  <!-- Hero -->
  <section class="hero-light relative overflow-hidden">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-36">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
        <!-- Text stânga -->
        <div class="flex-1 max-w-2xl">
          <p class="blur-in blur-in-1 text-amber-brand font-semibold text-lg mb-3 tracking-wide uppercase">
            Asociația Carla's Vision
          </p>
          <h1 class="blur-in blur-in-2 text-5xl sm:text-7xl lg:text-6xl font-extrabold leading-tight mb-3 lg:whitespace-nowrap text-amber-brand">
            {tr.hero.headline}
          </h1>
          <h2 class="blur-in blur-in-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold text-amber-brand mb-6">
            {tr.hero.subheadline}
          </h2>
          <p class="blur-in blur-in-4 text-navy-700 text-lg sm:text-xl leading-relaxed mb-8">
            {tr.hero.description}
          </p>
          <div class="blur-in blur-in-5 flex flex-col sm:flex-row gap-4">
            <a
              href={r.form230}
              class="inline-flex items-center justify-center px-8 py-4 bg-amber-brand text-navy-950 font-bold text-lg rounded-lg hover:bg-amber-brand-dark transition-colors shadow-lg"
            >
              {tr.hero.cta_form230}
            </a>
          </div>
        </div>
        <!-- Logo simbol dreapta (fără text) -->
        <div class="blur-in blur-in-3 flex-shrink-0 flex items-center justify-center lg:justify-end">
          <svg viewBox="0 0 180 150" width="320" height="267" role="img" aria-label="Carla's Vision" xmlns="http://www.w3.org/2000/svg" class="w-56 sm:w-72 lg:w-80 xl:w-96 h-auto logo-pulse">
            <path d="M90,75 C90,75 76,50 55,49 C36,48 20,60 20,75 C20,90 36,102 55,101 C76,100 90,75 90,75 C90,75 104,50 125,49 C144,48 160,60 160,75 C160,90 144,102 125,101 C104,100 90,75 90,75Z" fill="none" stroke="#DEBF6E" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M90,75 C90,75 77,57 60,56 C47,55 32,64 32,75 C32,86 46,93 60,94 C77,95 89,77 90,75 C90,75 103,57 120,56 C133,55 148,64 148,75 C148,86 134,93 120,94 C103,95 91,77 90,75Z" fill="none" stroke="#E2C878" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.587"/>
            <ellipse cx="55" cy="75" rx="28" ry="20" fill="none" stroke="#C9A84C" stroke-width="1" opacity="0.35"/>
            <ellipse cx="125" cy="75" rx="28" ry="20" fill="none" stroke="#C9A84C" stroke-width="1" opacity="0.35"/>
            <path d="M40,61 Q47,57 54,59" fill="none" stroke="#F5EBC8" stroke-width="0.8" stroke-linecap="round" opacity="0.5"/>
            <path d="M110,61 Q117,57 124,59" fill="none" stroke="#F5EBC8" stroke-width="0.8" stroke-linecap="round" opacity="0.5"/>
            <circle cx="55" cy="75" r="1.5" fill="#E8D080" opacity="0.75"/>
            <circle cx="125" cy="75" r="1.5" fill="#E8D080" opacity="0.26"/>
            <circle cx="90" cy="75" r="1.2" fill="#E8D080" opacity="0.6"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-navy-900 text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
        <div>
          <div class="text-4xl font-extrabold text-amber-brand">{org.stats.consultatii}+</div>
          <div class="text-navy-300 mt-1">{tr.stats.consultations}</div>
        </div>
        <div class="sm:border-x border-navy-700">
          <div class="text-4xl font-extrabold text-amber-brand">{org.stats.ochelari}+</div>
          <div class="text-navy-300 mt-1">{tr.stats.glasses}</div>
        </div>
        <div>
          <div class="text-4xl font-extrabold text-amber-brand">{org.stats.comunitati}</div>
          <div class="text-navy-300 mt-1">{tr.stats.communities}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission / Stories -->
  <section class="py-20 bg-gradient-to-br from-navy-900 via-navy-800 to-navy-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-bold text-white">{tr.mission.title}</h2>
        <p class="text-navy-200 mt-3 text-lg">{tr.mission.subtitle}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Story 1: Copil -->
        <div class="glass-card rounded-2xl p-8">
          <div class="w-14 h-14 bg-white/20 rounded-full flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">{tr.mission.story1_title}</h3>
          <p class="text-navy-100 leading-relaxed">{tr.mission.story1_text}</p>
        </div>

        <!-- Story 2: Parinte -->
        <div class="glass-card rounded-2xl p-8">
          <div class="w-14 h-14 bg-white/20 rounded-full flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">{tr.mission.story2_title}</h3>
          <p class="text-navy-100 leading-relaxed">{tr.mission.story2_text}</p>
        </div>

        <!-- Story 3: Bunic -->
        <div class="glass-card rounded-2xl p-8">
          <div class="w-14 h-14 bg-white/20 rounded-full flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">{tr.mission.story3_title}</h3>
          <p class="text-navy-100 leading-relaxed">{tr.mission.story3_text}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-20 bg-navy-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-900">{tr.how.title}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { num: "1", title: tr.how.step1_title, text: tr.how.step1_text },
          { num: "2", title: tr.how.step2_title, text: tr.how.step2_text },
          { num: "3", title: tr.how.step3_title, text: tr.how.step3_text },
        ].map((step) => (
          <div class="flex flex-col items-center text-center">
            <div class="w-16 h-16 bg-navy-900 text-white rounded-full flex items-center justify-center text-2xl font-extrabold mb-5 shadow-lg">
              {step.num}
            </div>
            <h3 class="text-xl font-bold text-navy-900 mb-3">{step.title}</h3>
            <p class="text-body leading-relaxed">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Projects -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-3xl sm:text-4xl font-bold text-navy-900">{tr.projects.title}</h2>
          <p class="text-muted mt-2">{tr.projects.subtitle}</p>
        </div>
        <a href={r.projects} class="hidden sm:inline-flex items-center gap-2 text-navy-700 font-semibold hover:text-navy-900 transition-colors">
          {tr.projects.see_all}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {proiecteRecente.map((proiect) => (
          <article class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
            <div class="bg-navy-100 h-40 flex items-center justify-center">
              <svg class="w-16 h-16 text-navy-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </div>
            <div class="p-6">
              <h3 class="font-bold text-navy-900 text-lg mb-2">{proiect.data.titlu}</h3>
              <p class="text-body text-sm leading-relaxed mb-4">{proiect.data.descriere}</p>
              <div class="flex items-center justify-between text-sm text-muted">
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  {proiect.data.beneficiari} {tr.projects.beneficiaries}
                </span>
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  </svg>
                  {proiect.data.locatie}
                </span>
              </div>
            </div>
          </article>
        ))}
      </div>
      <div class="text-center mt-8 sm:hidden">
        <a href={r.projects} class="inline-flex items-center gap-2 text-navy-700 font-semibold">{tr.projects.see_all} →</a>
      </div>
    </div>
  </section>

  <!-- CTA Form 230 -->
  <section class="py-20 bg-gradient-to-r from-navy-900 to-navy-700 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">{tr.form230.title}</h2>
      <p class="text-navy-200 text-lg mb-8 max-w-2xl mx-auto">{tr.form230.subtitle}</p>
      <a
        href={r.form230}
        class="inline-block px-8 py-4 bg-amber-brand text-navy-950 font-bold text-lg rounded-lg hover:bg-amber-brand-dark transition-colors"
      >
        {tr.nav.form230}
      </a>
    </div>
  </section>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import { t, routes } from "../../i18n/translations";
import { getCollection } from "astro:content";

const lang = "en";
const tr = t(lang);
const r = routes[lang];

const proiecte = await getCollection("proiecte");
const proiecteSortate = proiecte.sort(
  (a, b) => b.data.data.getTime() - a.data.data.getTime()
);
---

<Layout title="Projects" lang={lang} currentPage="projects">
  <section class="bg-gradient-to-br from-navy-900 to-navy-700 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold mb-4">{tr.projects.title}</h1>
      <p class="text-navy-200 text-xl max-w-2xl">{tr.projects.subtitle}</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {proiecteSortate.map((proiect) => (
          <article class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col">
            <div class="bg-navy-100 h-48 flex items-center justify-center relative">
              {proiect.data.imagine ? (
                <img src={proiect.data.imagine} alt={proiect.data.title} class="w-full h-full object-cover" />
              ) : (
                <svg class="w-20 h-20 text-navy-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              )}
              <div class="absolute top-3 right-3 bg-navy-900 text-white text-xs px-2 py-1 rounded-full">
                {proiect.data.data.toLocaleDateString("en-GB", { year: "numeric", month: "short" })}
              </div>
            </div>
            <div class="p-6 flex flex-col flex-1">
              <h2 class="font-bold text-navy-900 text-xl mb-3">{proiect.data.title}</h2>
              <p class="text-body text-sm leading-relaxed mb-4 flex-1">{proiect.data.description}</p>
              <div class="flex items-center justify-between text-sm text-muted pt-4 border-t border-gray-100">
                <span class="font-medium text-navy-700">{proiect.data.beneficiari} {tr.projects.beneficiaries}</span>
                <span>{proiect.data.locatie}</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
